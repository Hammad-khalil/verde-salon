rules_version = '2';

/**
 * Verde Salon CMS Security Rules
 *
 * Core Philosophy:
 * 1. Public content (Blogs, Services, Pages, etc.) is globally readable (get and list).
 * 2. Administrative actions (Create, Update, Delete) are restricted to authenticated administrators.
 * 3. Users signed in via the 'password' provider or with specific verified emails are granted admin rights.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.firebase.sign_in_provider == 'password' ||
        request.auth.token.email == 'hammad.khalil.work@gmail.com' ||
        request.auth.token.email == 'editor@verdesalon.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Rules ---

    // Roles and Admin Users
    match /roles_admin/{adminUserId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /admin_users/{adminUserId} {
      allow get, list: if isAdmin() || isOwner(adminUserId);
      allow create: if (isAdmin() || isOwner(adminUserId)) && request.resource.data.id == adminUserId;
      allow update: if (isAdmin() || (resource != null && isOwner(adminUserId))) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin() || (resource != null && isOwner(adminUserId));
    }

    // Global Settings
    match /settings/global {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // CMS Content - Publicly readable (get and list), admin writable
    match /cms_pages/{pageId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /cms_page_sections/{sectionId} {
      allow get, list: if true; 
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /service_categories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /blog_posts/{postId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /blog_categories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /blog_tags/{tagId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /gallery_images/{imageId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /gallery_categories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /faqs/{faqId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // Form Submissions - Admin only for reading, public for creating
    match /form_submissions/{submissionId} {
      allow create: if true; 
      allow get, list, update, delete: if isAdmin();
    }
  }
}