rules_version = '2';

/**
 * Verde Salon CMS Security Rules
 *
 * Core Philosophy:
 * This ruleset implements a robust administrative-access model (DBAC) designed for a 
 * professional CMS. Security is centralized around a `roles_admin` collection, where 
 * the presence of a user's UID determines their administrative privileges.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPublished() {
      return resource != null && resource.data.isPublished == true;
    }

    function isApproved() {
      return resource != null && resource.data.isApproved == true;
    }

    // --- Rules ---

    match /roles_admin/{adminUserId} {
      allow get: if isAdmin() || isOwner(adminUserId);
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /admin_users/{adminUserId} {
      allow get: if isAdmin() || isOwner(adminUserId);
      allow list: if isAdmin();
      allow create: if (isAdmin() || isOwner(adminUserId)) && request.resource.data.id == adminUserId;
      allow update: if (isAdmin() || (resource != null && isOwner(adminUserId))) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin() || (resource != null && isOwner(adminUserId));
    }

    match /settings/global {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /cms_pages/{pageId} {
      allow get: if isAdmin() || resource == null || isPublished();
      allow list: if true; 
      allow create, update, delete: if isAdmin();
    }

    match /cms_page_sections/{sectionId} {
      // Sections are public if the page they belong to is published.
      // For simplicity in this MVP, we allow public read for rendering.
      allow get, list: if true; 
      allow create, update, delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow get: if isAdmin() || resource == null || isPublished();
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /service_categories/{categoryId} {
      allow get: if isAdmin() || resource == null || isPublished();
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /blog_posts/{postId} {
      allow get: if isAdmin() || resource == null || isPublished();
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /blog_categories/{categoryId} {
      allow get: if isAdmin() || resource == null || isPublished();
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /blog_tags/{tagId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow get: if isAdmin() || resource == null || isApproved();
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /gallery_images/{imageId} {
      allow get: if isAdmin() || resource == null || isPublished();
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /faqs/{faqId} {
      allow get: if isAdmin() || resource == null || isPublished();
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /form_submissions/{submissionId} {
      allow get, list, create, update, delete: if isAdmin();
    }
  }
}