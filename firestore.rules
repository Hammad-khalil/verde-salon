rules_version = '2';

/**
 * Verde Salon CMS Security Rules
 *
 * Core Philosophy:
 * This ruleset implements a robust administrative-access model. 
 * In this prototype, any user signed in via the 'password' provider is granted 
 * administrative privileges to allow for seamless initial setup and management.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Allow access if the user has an explicit admin role document 
      // OR if they are signed in with a password (standard for CMS users).
      return isSignedIn() && (
        request.auth.token.firebase.sign_in_provider == 'password' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPublished() {
      return resource != null && resource.data.isPublished == true;
    }

    function isApproved() {
      return resource != null && resource.data.isApproved == true;
    }

    // --- Rules ---

    match /roles_admin/{adminUserId} {
      allow get: if isAdmin() || isOwner(adminUserId);
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /admin_users/{adminUserId} {
      allow get: if isAdmin() || isOwner(adminUserId);
      allow list: if isAdmin();
      allow create: if (isAdmin() || isOwner(adminUserId)) && request.resource.data.id == adminUserId;
      allow update: if (isAdmin() || (resource != null && isOwner(adminUserId))) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin() || (resource != null && isOwner(adminUserId));
    }

    match /settings/global {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /cms_pages/{pageId} {
      allow get: if isAdmin() || resource == null || isPublished();
      allow list: if true; 
      allow create, update, delete: if isAdmin();
    }

    match /cms_page_sections/{sectionId} {
      allow get, list: if true; 
      allow create, update, delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow get: if isAdmin() || resource == null || isPublished();
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /service_categories/{categoryId} {
      allow get: if isAdmin() || resource == null || isPublished();
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /blog_posts/{postId} {
      allow get: if isAdmin() || resource == null || isPublished();
      allow list: if true; 
      allow create, update, delete: if isAdmin();
    }
    
    match /blog_categories/{categoryId} {
      allow get: if isAdmin() || resource == null || isPublished();
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }
    
    match /blog_tags/{tagId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow get: if isAdmin() || resource == null || isApproved();
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /gallery_images/{imageId} {
      allow get: if isAdmin() || resource == null || isPublished();
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /gallery_categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /faqs/{faqId} {
      allow get: if isAdmin() || resource == null || isPublished();
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /form_submissions/{submissionId} {
      allow get, list, create, update, delete: if isAdmin();
    }
  }
}